{
  "manifest_version": 3,
  "name": "賃貸物件 条件一覧アシスタント",
  "version": "0.2.0",
  "description": "HOME'S / SUUMO / athome の条件一覧にコメント・色分け・非表示機能を追加",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.homes.co.jp/search/condition-list/*",
    "https://www.homes.co.jp/search/condition1/*",
    "https://www.homes.co.jp/list/*",
    "https://suumo.jp/jj/chintai/ichiran/FR301FC001/*",
    "https://www.athome.co.jp/chintai/tokyo/list/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.homes.co.jp/search/condition-list/*",
        "https://www.homes.co.jp/search/condition1/*",
        "https://www.homes.co.jp/list/*",
        "https://suumo.jp/jj/chintai/ichiran/FR301FC001/*",
        "https://www.athome.co.jp/chintai/tokyo/list/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
